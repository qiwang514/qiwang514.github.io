        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.wq.seckill.mapper.UserMapper">


    <resultMap id="BaseResultMap" type="com.wq.seckill.pojo.User">
        <!--User也可以-->
        <id column="id" property="id"/>
